{
  "name": "gitflow",
  "displayName": "gitflow",
  "description": "AI-powered git workflow automation",
  "version": "1.0.0",
  "publisher": "atsharma",
  "engines": {
    "vscode": "^1.85.0",
    "node": ">=24.0.0"
  },
  "categories": [
    "Other"
  ],
  "icon": "media/icon.png",
  "activationEvents": [
    "*"
  ],
  "main": "./dist/extension.js",
  "scripts": {
    "build:webview": "cd ../webview && npm run build",
    "copy:webview": "node -e \"const fs=require('node:fs');const path=require('node:path');const src=path.resolve(__dirname,'../webview/dist');const dest=path.resolve(__dirname,'media/webview');fs.rmSync(dest,{recursive:true,force:true});fs.mkdirSync(dest,{recursive:true});fs.cpSync(src,dest,{recursive:true});\"",
    "build": "npm run build:webview && npm run copy:webview && tsc -p .",
    "watch": "tsc -p . --watch"
  },
  "contributes": {
    "commands": [
      {
        "command": "gitflow.commit",
        "title": "gitflow: Generate commit message"
      },
      {
        "command": "gitflow.createPR",
        "title": "gitflow: Create PR with description"
      },
      {
        "command": "gitflow.reviewPR",
        "title": "gitflow: Review current PR"
      },
      {
        "command": "gitflow.fixAllBlockers",
        "title": "gitflow: Fix all blocker comments"
      },
      {
        "command": "gitflow.fixComment",
        "title": "gitflow: Fix selected comment"
      },
      {
        "command": "gitflow.switchModel",
        "title": "gitflow: Switch AI model"
      },
      {
        "command": "gitflow.auth",
        "title": "gitflow: Setup or update API keys"
      },
      {
        "command": "gitflow.showPanel",
        "title": "gitflow: Show gitflow panel"
      },
      {
        "command": "gitflow.status",
        "title": "gitflow: Show status"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "gitflow",
          "title": "gitflow",
          "icon": "media/activity-bar.png"
        }
      ]
    },
    "views": {
      "gitflow": [
        {
          "type": "webview",
          "id": "gitflow.panel",
          "name": "gitflow"
        }
      ]
    }
  },
  "dependencies": {
    "js-yaml": "^4.1.1",
    "keytar": "^7.9.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.6.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^6.0.3"
  }
}
